NODE_ENV=development
PORT=5000
HOST=0.0.0.0
SQLITE_PATH=
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=24h
# Clé secrète pour signer les licences (à garder confidentielle côté vendeur)
LICENSE_SIGNING_SECRET=change-me-license-signing-secret
# Chiffrement des données licence en base (optionnel, défaut = LICENSE_SIGNING_SECRET)
LICENSE_ENCRYPTION_SECRET=change-me-license-encryption-secret
SESSION_TIMEOUT_MINUTES=20
PIN_MAX_ATTEMPTS=5
PIN_LOCK_MINUTES=15
CORS_ORIGIN=http://localhost:5173
# En production sur réseau local, mettre ALLOW_LAN_CORS=true
ALLOW_LAN_CORS=true
# Electron / POS local (http) — cookies auth sans HTTPS ; n'annule pas la licence machine
TouDev_LOCAL_POS=1
